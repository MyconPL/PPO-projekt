<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SchoolApp.Maui.Views.MainPage">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="School App" FontSize="28" />

        <!-- ADD STUDENT -->
        <Entry Placeholder="Student name"
               Text="{Binding NewStudentName}" />

        <Button Text="Add student"
                Clicked="OnAddStudentClicked" />

        <!-- ADD GRADE -->
        <Entry Placeholder="Student name"
               Text="{Binding GradeStudentName}" />

        <Entry Placeholder="Grade (1-6)"
               Keyboard="Numeric"
               Text="{Binding GradeValue}" />

        <Button Text="Add grade"
                Clicked="OnAddGradeClicked" />

        <!-- STUDENTS LIST -->
        <CollectionView ItemsSource="{Binding Students}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout>
                        <Label Text="{Binding Name}" FontSize="18"/>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>