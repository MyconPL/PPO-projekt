<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PPO_projekt.MAUI.MainPage">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="12">

            <Label Text="School App"
                   FontSize="28"
                   HorizontalOptions="Center" />

            <!-- ADD STUDENT -->
            <Entry Placeholder="Student name"
                   Text="{Binding NewStudentName}" />

            <Button Text="Add student"
                    Clicked="OnAddStudentClicked" />

            <BoxView HeightRequest="1" Color="Gray"/>

            <!-- ADD GRADE -->
            <Entry Placeholder="Student name"
                   Text="{Binding GradeStudentName}" />

            <Entry Placeholder="Grade (1-6)"
                   Keyboard="Numeric"
                   Text="{Binding GradeValue}" />

            <Button Text="Add grade"
                    Clicked="OnAddGradeClicked" />

            <BoxView HeightRequest="1" Color="Gray"/>

            <!-- LIST -->
            <CollectionView ItemsSource="{Binding Students}">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="10">

                            <Label Text="{Binding Name}"
                                   FontSize="18" />

                            <Label Text="{Binding GetAverage, StringFormat='Average: {0:F2}'}"
                                   TextColor="Gray" />

                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>